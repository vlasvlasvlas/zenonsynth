{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zenonsynth.local/schemas/preset.schema.json",
  "title": "ZenonSynthPreset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "engine",
    "runners",
    "voices",
    "modMatrix",
    "fx"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "author",
        "createdAt"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "version": {
          "type": "string",
          "pattern": "^1\\.0\\.0$"
        },
        "author": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tempoConvergence",
        "maxVoices",
        "qualityMode"
      ],
      "properties": {
        "tempoConvergence": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 8
        },
        "maxVoices": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "qualityMode": {
          "type": "string",
          "enum": [
            "eco",
            "normal",
            "high"
          ]
        }
      }
    },
    "runners": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "$ref": "#/$defs/runner"
      }
    },
    "voices": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "$ref": "#/$defs/voice"
      }
    },
    "modMatrix": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/modSlot"
      }
    },
    "fx": {
      "$ref": "#/$defs/fxRack"
    }
  },
  "$defs": {
    "path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "params"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "line",
            "circle",
            "spiral"
          ]
        },
        "params": {
          "type": "object"
        }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "enabled",
        "color",
        "pursuit",
        "path",
        "targetRef",
        "voiceRef",
        "historySize"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]{2,40}$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "enabled": {
          "type": "boolean"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "pursuit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "ratio",
            "fixedStep",
            "expLambda"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "fractional",
                "fixed_step",
                "exponential"
              ]
            },
            "ratio": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 0.999999
            },
            "fixedStep": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "expLambda": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        },
        "path": {
          "$ref": "#/$defs/path"
        },
        "targetRef": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "voiceRef": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]{2,40}$"
        },
        "historySize": {
          "type": "integer",
          "minimum": 16,
          "maximum": 2000
        }
      }
    },
    "oscillator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wave",
        "gain",
        "detuneCents",
        "octave",
        "phase"
      ],
      "properties": {
        "wave": {
          "type": "string",
          "enum": [
            "sine",
            "square",
            "triangle",
            "saw",
            "noise"
          ]
        },
        "gain": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "detuneCents": {
          "type": "number",
          "minimum": -2400,
          "maximum": 2400
        },
        "octave": {
          "type": "integer",
          "minimum": -4,
          "maximum": 4
        },
        "phase": {
          "type": "number",
          "minimum": 0,
          "maximum": 360
        }
      }
    },
    "lfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "wave",
        "rateHz",
        "depth",
        "phase",
        "sync"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]{2,40}$"
        },
        "wave": {
          "type": "string",
          "enum": [
            "sine",
            "triangle",
            "square",
            "saw",
            "sample_hold"
          ]
        },
        "rateHz": {
          "type": "number",
          "exclusiveMinimum": 0.01,
          "maximum": 40
        },
        "depth": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "phase": {
          "type": "number",
          "minimum": 0,
          "maximum": 360
        },
        "sync": {
          "type": "boolean"
        }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "enabled",
        "gain",
        "pan",
        "oscillators",
        "noise",
        "ampEnv",
        "filter",
        "lfos"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]{2,40}$"
        },
        "enabled": {
          "type": "boolean"
        },
        "gain": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "pan": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "oscillators": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": {
            "$ref": "#/$defs/oscillator"
          }
        },
        "noise": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "color",
            "gain"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "color": {
              "type": "string",
              "enum": [
                "white",
                "pink",
                "brown"
              ]
            },
            "gain": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "ampEnv": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "attack",
            "decay",
            "sustain",
            "release",
            "curve"
          ],
          "properties": {
            "attack": {
              "type": "number",
              "minimum": 0,
              "maximum": 30
            },
            "decay": {
              "type": "number",
              "minimum": 0,
              "maximum": 30
            },
            "sustain": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "release": {
              "type": "number",
              "minimum": 0,
              "maximum": 30
            },
            "curve": {
              "type": "string",
              "enum": [
                "lin",
                "exp"
              ]
            }
          }
        },
        "filter": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "routing",
            "lowpass",
            "highpass",
            "bandpass"
          ],
          "properties": {
            "routing": {
              "type": "string",
              "enum": [
                "hp_lp",
                "lp_hp",
                "bp"
              ]
            },
            "lowpass": {
              "$ref": "#/$defs/filterNode"
            },
            "highpass": {
              "$ref": "#/$defs/filterNode"
            },
            "bandpass": {
              "$ref": "#/$defs/filterNode"
            }
          }
        },
        "lfos": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "$ref": "#/$defs/lfo"
          }
        }
      }
    },
    "filterNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cutoffHz",
        "q"
      ],
      "properties": {
        "cutoffHz": {
          "type": "number",
          "minimum": 10,
          "maximum": 22050
        },
        "q": {
          "type": "number",
          "minimum": 0.0001,
          "maximum": 40
        }
      }
    },
    "modSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "enabled",
        "source",
        "destination",
        "amount",
        "bipolar",
        "transform"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]{2,40}$"
        },
        "enabled": {
          "type": "boolean"
        },
        "source": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "destination": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "amount": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "bipolar": {
          "type": "boolean"
        },
        "transform": {
          "type": "string",
          "enum": [
            "linear",
            "exp",
            "log",
            "step"
          ]
        }
      }
    },
    "fxRack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "saturation",
        "delay",
        "reverb",
        "limiter"
      ],
      "properties": {
        "saturation": {
          "$ref": "#/$defs/fxSaturation"
        },
        "delay": {
          "$ref": "#/$defs/fxDelay"
        },
        "reverb": {
          "$ref": "#/$defs/fxReverb"
        },
        "limiter": {
          "$ref": "#/$defs/fxLimiter"
        }
      }
    },
    "fxSaturation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "drive",
        "mix"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "drive": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "mix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "fxDelay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "timeMs",
        "feedback",
        "mix",
        "highCutHz"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "timeMs": {
          "type": "number",
          "minimum": 1,
          "maximum": 4000
        },
        "feedback": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.99
        },
        "mix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "highCutHz": {
          "type": "number",
          "minimum": 200,
          "maximum": 22050
        }
      }
    },
    "fxReverb": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "preDelayMs",
        "decaySec",
        "dampHz",
        "mix"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "preDelayMs": {
          "type": "number",
          "minimum": 0,
          "maximum": 250
        },
        "decaySec": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 20
        },
        "dampHz": {
          "type": "number",
          "minimum": 200,
          "maximum": 22050
        },
        "mix": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "fxLimiter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "thresholdDb",
        "releaseSec"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "thresholdDb": {
          "type": "number",
          "minimum": -24,
          "maximum": 0
        },
        "releaseSec": {
          "type": "number",
          "minimum": 0.001,
          "maximum": 2
        }
      }
    }
  }
}
